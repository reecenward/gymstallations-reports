JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=720
DB_PATH=./data/app.db

CORS_ORIGINS=http://localhost:5173

# Webhook that receives a simple "new report" notification. The backend POSTs:
# { event, report_id, created_by, created_at, job_number, client_name, link }
FORM_HANDLER_URL=https://example.com/form-handler-placeholder

# Public base URL of the app — used to build the "view report" link sent in
# the notification (e.g. https://reports.example.com).
APP_BASE_URL=
